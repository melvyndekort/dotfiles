#!/bin/bash

# Rofi script-mode menu for managing Bluetooth audio devices.
# Handles connect (with auto-pair), disconnect, and profile switching.

for cmd in rofi bluetoothctl pactl notify-send; do
    command -v "$cmd" >/dev/null || { echo "$cmd not found" >&2; exit 1; }
done

# --- Helpers ---

# List audio devices with connection status (MAC|Name|connected/disconnected)
get_audio_devices() {
    {
        bluetoothctl devices Paired
        bluetoothctl devices Trusted
    } 2>/dev/null | sort -u | while read -r _ mac name; do
        local info
        info=$(bluetoothctl info "$mac" 2>/dev/null)
        if echo "$info" | grep -qE '(UUID: Audio Sink|Icon: audio-card)'; then
            if echo "$info" | grep -q "Connected: yes"; then
                echo "$mac|$name|connected"
            else
                echo "$mac|$name|disconnected"
            fi
        fi
    done
}

# Get bluetooth audio cards with current profile (card|description|profile)
get_bt_cards() {
    pactl list cards 2>/dev/null | awk '
        /Name: bluez_card\./ { card = $2 }
        card && /device\.description = / {
            gsub(/"/, "", $0)
            sub(/.*device\.description = /, "", $0)
            desc = $0
        }
        card && /Active Profile:/ {
            print card "|" desc "|" $3
            card = ""
        }
    '
}

# Get available profiles for a card (id|description)
get_profiles() {
    pactl list cards 2>/dev/null | awk -v target="$1" '
        /Name: / { current = $2 }
        current == target && /Profiles:/ { show = 1; next }
        current == target && /Active Profile:/ { show = 0 }
        current == target && show && /^\t\t[a-z].*available: yes/ {
            sub(/^\t\t/, "")
            idx = index($0, ": ")
            id = substr($0, 1, idx - 1)
            rest = substr($0, idx + 2)
            sub(/ \(sinks:.*/, "", rest)
            if (id != "off") print id "|" rest
        }
    '
}

# Connect a device by MAC, handling pairing if needed
bt_connect() {
    local mac="$1"
    local paired
    paired=$(bluetoothctl info "$mac" 2>/dev/null | awk '/Paired:/ {print $2}')

    if [[ "$paired" != "yes" ]]; then
        # Auto-pair with passkey auto-confirm (bypasses Blueman's agent)
        timeout 20 bash -c '
            {
                echo "agent NoInputNoOutput"
                sleep 1
                echo "default-agent"
                sleep 1
                echo "pair $1"
                sleep 3
                echo "yes"
                sleep 2
                echo "connect $1"
                sleep 5
                echo "quit"
            } | bluetoothctl
        ' _ "$mac" &>/dev/null
        bluetoothctl info "$mac" 2>/dev/null | grep -q "Connected: yes"
    else
        local attempt
        for attempt in 1 2 3; do
            bluetoothctl connect "$mac" &>/dev/null
            if bluetoothctl info "$mac" 2>/dev/null | grep -q "Connected: yes"; then
                return 0
            fi
            sleep 2
        done
        return 1
    fi
}

# --- Rofi script mode ---

# ROFI_DATA persists state between invocations
echo -e "\0no-custom\x1ftrue"

if [[ $# -eq 0 ]]; then
    echo -e "\0prompt\x1fBluetooth"
    echo -e "\0data\x1fmain"
    echo "Switch Profile"
    echo "Connect"
    echo "Disconnect"
    exit 0
fi

SELECTION="$*"

case "$ROFI_DATA" in
    main)
        case "$SELECTION" in
            "Switch Profile")
                echo -e "\0prompt\x1fSwitch Profile"
                echo -e "\0data\x1fprofile-device"
                cards=$(get_bt_cards)
                if [[ -z "$cards" ]]; then
                    notify-send "Bluetooth" "No connected Bluetooth audio devices"
                    exit 0
                fi
                while IFS='|' read -r _ desc active; do
                    echo "$desc [$active]"
                done <<< "$cards"
                ;;
            "Connect")
                echo -e "\0prompt\x1fConnect"
                echo -e "\0data\x1fconnect"
                devices=$(get_audio_devices | grep '|disconnected$')
                if [[ -z "$devices" ]]; then
                    notify-send "Bluetooth" "No disconnected audio devices available"
                    exit 0
                fi
                while IFS='|' read -r _ name _; do
                    echo "$name"
                done <<< "$devices"
                ;;
            "Disconnect")
                echo -e "\0prompt\x1fDisconnect"
                echo -e "\0data\x1fdisconnect"
                devices=$(get_audio_devices | grep '|connected$')
                if [[ -z "$devices" ]]; then
                    notify-send "Bluetooth" "No connected audio devices"
                    exit 0
                fi
                while IFS='|' read -r _ name _; do
                    echo "$name"
                done <<< "$devices"
                ;;
        esac
        ;;

    connect)
        mac=$(get_audio_devices | awk -F'|' -v name="$SELECTION" '$2 == name {print $1}' | head -1)
        if [[ -z "$mac" ]]; then
            notify-send "Bluetooth" "Device not found: $SELECTION"
            exit 1
        fi
        if ! bt_connect "$mac"; then
            notify-send "Bluetooth" "Failed to connect: $SELECTION\nPut it in pairing mode and try again."
        fi
        ;;

    disconnect)
        mac=$(get_audio_devices | awk -F'|' -v name="$SELECTION" '$2 == name {print $1}' | head -1)
        if [[ -z "$mac" ]]; then
            notify-send "Bluetooth" "Device not found: $SELECTION"
            exit 1
        fi
        if ! bluetoothctl disconnect "$mac" &>/dev/null; then
            notify-send "Bluetooth" "Failed to disconnect: $SELECTION"
        fi
        ;;

    profile-device)
        device_desc="${SELECTION% \[*\]}"
        card=$(get_bt_cards | awk -F'|' -v desc="$device_desc" '$2 == desc {print $1; exit}')
        if [[ -z "$card" ]]; then
            notify-send "Bluetooth" "Device not found: $device_desc"
            exit 1
        fi
        echo -e "\0prompt\x1f$device_desc"
        echo -e "\0data\x1fprofile-select"
        while IFS='|' read -r _ desc; do
            echo "$desc"
        done <<< "$(get_profiles "$card")"
        ;;

    profile-select)
        while IFS='|' read -r card desc _; do
            while IFS='|' read -r pid pdesc; do
                if [[ "$SELECTION" == "$pdesc" ]]; then
                    pactl set-card-profile "$card" "$pid"
                    notify-send "Bluetooth" "$desc → $pdesc"
                    exit 0
                fi
            done <<< "$(get_profiles "$card")"
        done <<< "$(get_bt_cards)"
        notify-send "Bluetooth" "Profile not found: $SELECTION"
        ;;
esac
